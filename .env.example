# Discord App Credentials
DISCORD_APPLICATION_ID=        # From Developer Portal → General Information → Application ID
DISCORD_PUBLIC_KEY=            # From Developer Portal → General Information → Public Key
DISCORD_BOT_TOKEN=             # From Developer Portal → Bot → Token (Reset Token to generate)
DISCORD_GUILD_ID=              # Your test server ID (right-click server → Copy Server ID)

# Database (Neon - free tier at neon.tech)
DATABASE_URL=                  # postgres://user:pass@host/dbname?sslmode=require

# Auth (NextAuth.js)
NEXTAUTH_SECRET=               # Generate: openssl rand -hex 32
NEXTAUTH_URL=                  # https://your-app.vercel.app (or http://localhost:3000 locally)

# AI - Google Gemini (free at aistudio.google.com)
GEMINI_API_KEY=                # From Google AI Studio → Get API Key

# Admin seed account (used once to create the dashboard login)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=                # Choose a strong password
